{
  "manifest_version": 3,
  "name": "VRCVideoCacher Cookies Exporter",
  "version": "1.0.0",
  "description": "Sends your YouTube cookies to VRCVideoCacher running on localhost.",
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": [
    "https://*.youtube.com/",
    "http://localhost:9696/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "VRCVideoCacher Cookies Exporter",
    "default_popup": "popup.html"
  }
}
